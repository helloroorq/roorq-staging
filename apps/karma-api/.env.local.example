PORT=4000
CORS_ORIGIN=http://localhost:3000
KARMA_INTERNAL_API_KEY=dev-karma-internal-key

# Copy from Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI.
# Replace [YOUR-PASSWORD] with your database password and keep sslmode=require.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# Optional here because dev also reads apps/web/.env.local:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
